---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import Newsletter from '../../components/home/Newsletter.astro';
import { getCollection } from 'astro:content';
import { INDUSTRIES, NICHES } from '../../lib/constants';

export function getStaticPaths() {
  return INDUSTRIES.map(i => ({ params: { industry: i.slug } }));
}

const { industry: industrySlug } = Astro.params;
const industry = INDUSTRIES.find(i => i.slug === industrySlug)!;

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.industry === industrySlug);
const posts = allPosts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const industryContent: Record<string, { heading: string; intro: string; challenges: string[]; topChannels: string[] }> = {
  'real-estate': {
    heading: 'Growth Marketing for Real Estate Professionals',
    intro: 'Real estate is fiercely competitive and hyper-local. The agents and brokers who win consistently are those who master local SEO, Google Business Profile, Facebook/Instagram advertising, and content marketing that builds trust before a prospect ever picks up the phone.',
    challenges: ['Generating consistent listing leads', 'Standing out in hyper-local markets', 'Building trust digitally', 'Long sales cycles requiring nurture'],
    topChannels: ['Local SEO', 'Google Business Profile', 'Facebook & Instagram Ads', 'Email Nurture', 'YouTube', 'Content Marketing'],
  },
  'saas-b2b': {
    heading: 'B2B SaaS Growth Marketing Playbooks',
    intro: 'SaaS growth is a multi-motion game: product-led growth for self-serve, demand generation for mid-market, and ABM for enterprise. Our SaaS marketing guides cover the full funnel — from top-of-funnel awareness through trial activation, expansion, and retention.',
    challenges: ['Long B2B sales cycles', 'High CAC in competitive markets', 'Churn and negative NRR', 'Aligning sales and marketing'],
    topChannels: ['SEO & Content', 'LinkedIn Ads', 'Product-Led Growth', 'Email Automation', 'ABM', 'Webinars & Events'],
  },
  'ecommerce': {
    heading: 'E-commerce & DTC Growth Marketing',
    intro: 'E-commerce success requires mastering the full customer lifecycle: paid acquisition, on-site conversion, email retention, and loyalty. Our DTC guides cover Meta Ads, Google Shopping, Klaviyo automation, CRO, and the subscription commerce playbook.',
    challenges: ['Rising Meta and Google CPMs', 'Post-iOS 14 attribution', 'Cart abandonment', 'Customer LTV and retention'],
    topChannels: ['Meta Ads', 'Google Shopping', 'Email & SMS', 'SEO', 'CRO', 'Influencer Marketing'],
  },
  'healthcare': {
    heading: 'Healthcare & MedTech Marketing (HIPAA-Compliant)',
    intro: 'Healthcare marketing must balance trust, compliance, and patient education. Our guides help medical practices, telehealth companies, and medtech brands generate qualified leads while staying compliant with HIPAA, FDA, and platform advertising policies.',
    challenges: ['HIPAA compliance in digital marketing', 'Restricted ad targeting on Meta/Google', 'Building patient trust digitally', 'Long consideration cycles'],
    topChannels: ['Local SEO', 'Content Marketing', 'Email Nurture', 'Google Ads (compliant)', 'Patient Reviews', 'Social Proof'],
  },
  'fintech': {
    heading: 'Fintech & Financial Services Marketing',
    intro: 'Financial marketing combines tight compliance requirements with the need to build extraordinary trust in a skeptical market. Our fintech marketing guides cover compliant content strategies, performance marketing at scale, and brand-building for financial products.',
    challenges: ['Regulatory and compliance constraints', 'Building trust in a skeptical market', 'Highly competitive paid keywords', 'Complex multi-step onboarding funnels'],
    topChannels: ['SEO & Thought Leadership', 'Email Marketing', 'Paid Search', 'LinkedIn', 'Compliance-Safe Social', 'Referral Programs'],
  },
  'professional-services': {
    heading: 'Marketing for Law Firms, Consultancies & Accountants',
    intro: 'Professional services firms win clients through trust, reputation, and referrals — but digital channels can dramatically amplify all three. Our guides cover local SEO, LinkedIn thought leadership, content marketing for expertise, and pay-per-click for high-value service keywords.',
    challenges: ['Differentiating a commoditized service', 'Generating qualified leads vs. tire-kickers', 'Building online reputation', 'Justifying marketing spend to partners'],
    topChannels: ['Local SEO', 'LinkedIn', 'Google Ads', 'Content Marketing', 'Email Nurture', 'Review Management'],
  },
  'logistics': {
    heading: 'B2B Marketing for Logistics & Supply Chain',
    intro: 'Logistics is a relationship-driven industry increasingly disrupted by digital-first competitors. Our guides help 3PLs, freight brokers, and supply chain tech companies generate leads through content marketing, LinkedIn, and targeted paid campaigns reaching logistics decision-makers.',
    challenges: ['Long enterprise sales cycles', 'Reaching niche decision-makers', 'Commoditization and price competition', 'Demonstrating ROI to old-school buyers'],
    topChannels: ['LinkedIn Ads & Organic', 'SEO & Content', 'Email Sequences', 'Trade Publications', 'Webinars', 'ABM'],
  },
  'hospitality': {
    heading: 'Hospitality & Travel Marketing',
    intro: 'Hospitality brands live and die by their online reputation, OTA dependency, and direct booking rate. Our guides help hotels, vacation rentals, restaurants, and travel brands build direct channels, optimize for travel intent keywords, and leverage visual social media to drive bookings.',
    challenges: ['OTA dependency and margin erosion', 'Seasonality and demand fluctuation', 'Reputation management', 'Competing with aggregators on Google'],
    topChannels: ['Google Hotel Ads', 'Meta Visual Ads', 'Email Loyalty Programs', 'SEO & Travel Content', 'Review Management', 'Influencer Partnerships'],
  },
};

const content = industryContent[industrySlug] ?? {
  heading: `${industry.label} Marketing Strategies`,
  intro: `Expert marketing guides tailored for ${industry.label} businesses.`,
  challenges: [],
  topChannels: [],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://growthmarketinghub.com' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://growthmarketinghub.com/industries' },
    { '@type': 'ListItem', position: 3, name: industry.label, item: `https://growthmarketinghub.com/industries/${industrySlug}` },
  ],
};
---

<BaseLayout
  title={`${industry.label} Marketing`}
  description={industry.description}
  jsonLd={[breadcrumbSchema]}
>
  <!-- Hero -->
  <section class="border-b border-[var(--color-border)] bg-[var(--color-surface-2)]" aria-labelledby="industry-hero-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-[var(--color-text-muted)]" role="list">
          <li><a href="/" class="hover:text-[var(--color-brand)] transition-colors">Home</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/industries" class="hover:text-[var(--color-brand)] transition-colors">Industries</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-[var(--color-text)] font-medium" aria-current="page">{industry.label}</li>
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-4xl" aria-hidden="true">{industry.icon}</span>
          <span class="px-3 py-1 rounded-full text-xs font-semibold bg-[var(--color-brand)]/10 text-[var(--color-brand)] border border-[var(--color-brand)]/20">
            {posts.length} {posts.length === 1 ? 'article' : 'articles'}
          </span>
        </div>
        <h1 id="industry-hero-heading" class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--color-text)] mb-4">{content.heading}</h1>
        <p class="text-[var(--color-text-muted)] leading-relaxed">{content.intro}</p>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:grid lg:grid-cols-[1fr_280px] lg:gap-12">
    <div>
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-4xl mb-4" aria-hidden="true">✍️</p>
          <h2 class="font-serif text-xl font-semibold text-[var(--color-text)] mb-2">Content coming soon</h2>
          <p class="text-[var(--color-text-muted)]">We're building {industry.label} marketing guides. Subscribe to be first.</p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 gap-6">
          {posts.map(post => <ArticleCard post={post} />)}
        </div>
      )}
    </div>

    <aside class="mt-10 lg:mt-0 space-y-6">
      {content.challenges.length > 0 && (
        <div class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-2)]">
          <h2 class="font-semibold text-sm text-[var(--color-text)] mb-3">Key challenges we address</h2>
          <ul class="space-y-2" role="list">
            {content.challenges.map(c => (
              <li class="flex items-start gap-2 text-sm text-[var(--color-text-muted)]">
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] flex-shrink-0 mt-1.5" aria-hidden="true"></span>
                {c}
              </li>
            ))}
          </ul>
        </div>
      )}
      {content.topChannels.length > 0 && (
        <div class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-2)]">
          <h2 class="font-semibold text-sm text-[var(--color-text)] mb-3">Top channels for {industry.label}</h2>
          <div class="flex flex-wrap gap-2">
            {content.topChannels.map(ch => (
              <span class="px-2.5 py-1 rounded-full text-xs bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text-muted)]">{ch}</span>
            ))}
          </div>
        </div>
      )}
      <Newsletter />
      <div class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-2)]">
        <h2 class="font-semibold text-sm text-[var(--color-text)] mb-3">Other industries</h2>
        <ul class="space-y-2" role="list">
          {INDUSTRIES.filter(i => i.slug !== industrySlug).slice(0, 5).map(i => (
            <li>
              <a href={`/industries/${i.slug}`} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand)] transition-colors">
                <span aria-hidden="true">{i.icon}</span> {i.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  </div>
</BaseLayout>
