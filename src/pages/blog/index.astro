---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { NICHES } from '../../lib/constants';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const nicheParam = Astro.url.searchParams.get('niche') ?? 'all';
const filtered = nicheParam === 'all' ? sorted : sorted.filter(p => p.data.niche === nicheParam);
---

<BaseLayout
  title="Blog"
  description="In-depth articles, guides, and case studies on growth marketing across SEO, PPC, content, email, social media, and more."
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="max-w-2xl mb-10">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-3">Blog</h1>
      <p class="text-lg text-[var(--color-text-muted)]">Actionable growth marketing strategies, deep-dives, and real-world case studies.</p>
    </div>

    <!-- Niche filter -->
    <div class="mb-8 flex flex-wrap gap-2" role="navigation" aria-label="Filter by niche">
      <a
        href="/blog"
        class:list={[
          "px-4 py-1.5 rounded-full text-sm font-medium border transition-colors",
          nicheParam === 'all'
            ? "bg-[var(--color-brand)] text-white border-[var(--color-brand)]"
            : "border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-brand)] hover:text-[var(--color-brand)]",
        ]}
        aria-current={nicheParam === 'all' ? 'page' : undefined}
      >
        All
      </a>
      {NICHES.map(n => (
        <a
          href={`/blog?niche=${n.slug}`}
          class:list={[
            "px-4 py-1.5 rounded-full text-sm font-medium border transition-colors flex items-center gap-1.5",
            nicheParam === n.slug
              ? "bg-[var(--color-brand)] text-white border-[var(--color-brand)]"
              : "border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-brand)] hover:text-[var(--color-brand)]",
          ]}
          aria-current={nicheParam === n.slug ? 'page' : undefined}
        >
          <span aria-hidden="true">{n.icon}</span> {n.label}
        </a>
      ))}
    </div>

    <!-- Results -->
    {filtered.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-4xl mb-4" aria-hidden="true">📭</p>
        <h2 class="font-serif text-xl font-semibold text-[var(--color-text)] mb-2">No articles yet</h2>
        <p class="text-[var(--color-text-muted)]">Check back soon — new content is published weekly.</p>
        <a href="/blog" class="mt-4 inline-block text-sm font-medium text-[var(--color-brand)] hover:underline">View all articles</a>
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {filtered.map(post => <ArticleCard post={post} />)}
      </div>
    )}
  </div>
</BaseLayout>
