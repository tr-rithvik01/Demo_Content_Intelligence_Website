---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with the GrowthMarketing Hub team. For business inquiries, guest post pitches, corrections, or partnership opportunities."
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-2xl mb-10">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-3">Contact Us</h1>
      <p class="text-lg text-[var(--color-text-muted)]">Have a question, story pitch, or partnership idea? We'd love to hear from you.</p>
    </div>

    <div class="grid lg:grid-cols-[1fr_320px] gap-12">
      <!-- Form -->
      <div>
        <form
          id="contact-form"
          class="space-y-5"
          aria-label="Contact form"
          novalidate
        >
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="contact-name" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">
                Full name <span class="text-red-500" aria-label="required">*</span>
              </label>
              <input
                id="contact-name"
                type="text"
                name="name"
                required
                autocomplete="name"
                placeholder="Jane Smith"
                class="w-full px-4 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)] placeholder-[var(--color-text-muted)]"
                aria-required="true"
              />
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">
                Email address <span class="text-red-500" aria-label="required">*</span>
              </label>
              <input
                id="contact-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="jane@company.com"
                class="w-full px-4 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)] placeholder-[var(--color-text-muted)]"
                aria-required="true"
              />
            </div>
          </div>

          <div>
            <label for="contact-subject" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">
              Subject <span class="text-red-500" aria-label="required">*</span>
            </label>
            <select
              id="contact-subject"
              name="subject"
              required
              class="w-full px-4 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)]"
              aria-required="true"
            >
              <option value="">Select a subject…</option>
              <option value="general">General enquiry</option>
              <option value="guest-post">Guest post pitch</option>
              <option value="partnership">Partnership / sponsorship</option>
              <option value="press">Press & media</option>
              <option value="correction">Report a factual error</option>
              <option value="advertising">Advertising</option>
            </select>
          </div>

          <div>
            <label for="contact-company" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">
              Company / website <span class="text-xs text-[var(--color-text-muted)] font-normal">(optional)</span>
            </label>
            <input
              id="contact-company"
              type="text"
              name="company"
              autocomplete="organization"
              placeholder="Acme Inc."
              class="w-full px-4 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)] placeholder-[var(--color-text-muted)]"
            />
          </div>

          <div>
            <label for="contact-message" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">
              Message <span class="text-red-500" aria-label="required">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="6"
              placeholder="Tell us what's on your mind…"
              class="w-full px-4 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)] placeholder-[var(--color-text-muted)] resize-y"
              aria-required="true"
            ></textarea>
          </div>

          <!-- Cloudflare Turnstile placeholder -->
          <div
            class="cf-turnstile"
            data-sitekey="REPLACE_WITH_TURNSTILE_SITE_KEY"
            data-theme="auto"
            aria-label="Security verification"
          ></div>
          <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

          <button
            type="submit"
            class="w-full px-6 py-3 rounded-xl bg-[var(--color-brand)] text-white font-semibold hover:opacity-90 transition-opacity disabled:opacity-50"
          >
            Send Message
          </button>

          <p id="contact-status" role="status" aria-live="polite" class="text-sm hidden"></p>
        </form>
      </div>

      <!-- Sidebar info -->
      <aside class="space-y-6">
        <div class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-2)]">
          <h2 class="font-semibold text-[var(--color-text)] mb-4">Response times</h2>
          <ul class="space-y-3 text-sm" role="list">
            {[
              { type: 'General enquiries', time: '2–3 business days' },
              { type: 'Guest post pitches', time: '5–7 business days' },
              { type: 'Partnership proposals', time: '3–5 business days' },
              { type: 'Factual corrections', time: '24–48 hours' },
            ].map(item => (
              <li class="flex items-center justify-between">
                <span class="text-[var(--color-text-muted)]">{item.type}</span>
                <span class="font-medium text-[var(--color-text)] text-xs bg-[var(--color-surface)] border border-[var(--color-border)] px-2 py-0.5 rounded-full">{item.time}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-2)]">
          <h2 class="font-semibold text-[var(--color-text)] mb-3">Guest post guidelines</h2>
          <ul class="space-y-2 text-sm text-[var(--color-text-muted)]" role="list">
            {[
              'Minimum 1,500 words, ideally 2,500+',
              'Unique, unpublished content only',
              'Must include data, examples, or case studies',
              'Author bio with verifiable credentials required',
              'No AI-only content — must be practitioner-written',
            ].map(g => (
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-[var(--color-brand)] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {g}
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('contact-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.reset();
        if (statusEl) {
          statusEl.textContent = 'Message sent! We\'ll be in touch within 2–3 business days.';
          statusEl.className = 'text-sm text-green-600';
        }
      } else {
        throw new Error('Server error');
      }
    } catch {
      if (statusEl) {
        statusEl.textContent = 'Something went wrong. Please try again or email us directly.';
        statusEl.className = 'text-sm text-red-500';
      }
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
