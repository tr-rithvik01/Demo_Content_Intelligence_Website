---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Search"
  description="Search all growth marketing guides, articles, and resources on GrowthMarketing Hub."
  noindex
>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-8">Search</h1>
    <div id="pagefind-search"></div>
  </div>
</BaseLayout>

<script is:inline>
  // Pagefind UI is generated at build time — load it via script tag to avoid bundler resolution
  (function () {
    var el = document.getElementById('pagefind-search');
    if (!el) return;
    var script = document.createElement('script');
    script.type = 'module';
    script.textContent = [
      'try {',
      '  const { PagefindUI } = await import("/pagefind/pagefind-ui.js");',
      '  new PagefindUI({ element: "#pagefind-search", showImages: false, showEmptyFilters: false });',
      '} catch (e) {',
      '  document.getElementById("pagefind-search").innerHTML =',
      '    \'<p style="color:var(--color-text-muted);font-size:.875rem">Search index not available in dev mode. Run <code>npm run build</code> first.</p>\';',
      '}',
    ].join('\n');
    document.head.appendChild(script);
  })();
</script>
