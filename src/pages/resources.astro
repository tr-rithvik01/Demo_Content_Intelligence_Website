---
import BaseLayout from '../layouts/BaseLayout.astro';
import { NICHES } from '../lib/constants';

const resources = [
  {
    category: 'Templates',
    icon: '📋',
    items: [
      { title: 'Content Calendar Template', description: '12-month editorial planning spreadsheet with niche filters and SEO fields.', niche: 'content-marketing', type: 'Google Sheets', free: true },
      { title: 'PPC Campaign Brief Template', description: 'Structured brief for any paid media campaign with KPIs, targeting, and creative specs.', niche: 'ppc', type: 'Google Docs', free: true },
      { title: 'Email Welcome Sequence Template', description: '5-email welcome series with subject lines, copy frameworks, and timing logic.', niche: 'email-marketing', type: 'PDF', free: true },
      { title: 'SEO Audit Checklist', description: '85-point technical SEO audit with explanations and priority scoring.', niche: 'seo', type: 'PDF', free: true },
    ],
  },
  {
    category: 'Guides',
    icon: '📖',
    items: [
      { title: 'The Local SEO Playbook 2025', description: 'End-to-end guide to ranking in the Map Pack and local organic results.', niche: 'local-seo', type: 'PDF', free: true },
      { title: 'AI Marketing Tools Directory', description: 'Curated list of 60+ AI marketing tools with use cases, pricing, and ratings.', niche: 'ai-tools', type: 'Notion', free: true },
      { title: 'CRO Testing Framework', description: 'Structured approach to A/B testing with statistical significance calculators.', niche: 'analytics-cro', type: 'PDF', free: true },
    ],
  },
  {
    category: 'Checklists',
    icon: '✅',
    items: [
      { title: 'New Blog Post SEO Checklist', description: '25-point checklist to validate every article before hitting publish.', niche: 'seo', type: 'PDF', free: true },
      { title: 'Google Ads Account Setup Checklist', description: 'Step-by-step new account setup to avoid the most common (and costly) mistakes.', niche: 'ppc', type: 'PDF', free: true },
      { title: 'Social Media Launch Checklist', description: 'Pre-launch checklist for entering a new social platform.', niche: 'social-media', type: 'PDF', free: true },
    ],
  },
  {
    category: 'Recommended Tools',
    icon: '🛠️',
    items: [
      { title: 'Ahrefs', description: 'Best-in-class SEO toolset for keyword research, backlink analysis, and site audits.', niche: 'seo', type: 'Tool', free: false, url: 'https://ahrefs.com' },
      { title: 'Google Search Console', description: 'Free, non-negotiable tool to monitor your site\'s search performance.', niche: 'seo', type: 'Tool', free: true, url: 'https://search.google.com/search-console' },
      { title: 'Klaviyo', description: 'Email & SMS platform built for e-commerce. Deep Shopify integration and powerful segmentation.', niche: 'email-marketing', type: 'Tool', free: false, url: 'https://www.klaviyo.com' },
      { title: 'Hotjar', description: 'Heatmaps, session recordings, and feedback widgets for understanding on-site behaviour.', niche: 'analytics-cro', type: 'Tool', free: false, url: 'https://www.hotjar.com' },
      { title: 'Claude', description: 'Best-in-class AI for long-form content, market research, and structured marketing tasks.', niche: 'ai-tools', type: 'Tool', free: false, url: 'https://claude.ai' },
      { title: 'Buttondown', description: 'Simple, privacy-respecting email newsletter tool with RSS-to-email built in.', niche: 'email-marketing', type: 'Tool', free: true, url: 'https://buttondown.com' },
    ],
  },
];

const activeFilter = Astro.url.searchParams.get('niche') ?? 'all';
---

<BaseLayout
  title="Free Marketing Resources"
  description="Free growth marketing templates, checklists, guides, and tool recommendations. Curated resources for marketers and business owners."
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="max-w-2xl mb-10">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-3">Free Resources</h1>
      <p class="text-lg text-[var(--color-text-muted)]">Templates, checklists, guides, and tool recommendations — curated to save you hours and get results faster.</p>
    </div>

    <!-- Filter -->
    <div class="mb-8 flex flex-wrap gap-2" role="navigation" aria-label="Filter resources">
      <a href="/resources" class:list={["px-4 py-1.5 rounded-full text-sm font-medium border transition-colors", activeFilter === 'all' ? "bg-[var(--color-brand)] text-white border-[var(--color-brand)]" : "border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-brand)]"]}>
        All
      </a>
      {NICHES.map(n => (
        <a href={`/resources?niche=${n.slug}`} class:list={["px-4 py-1.5 rounded-full text-sm font-medium border transition-colors flex items-center gap-1.5", activeFilter === n.slug ? "bg-[var(--color-brand)] text-white border-[var(--color-brand)]" : "border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-brand)]"]}>
          <span aria-hidden="true">{n.icon}</span> {n.label}
        </a>
      ))}
    </div>

    <!-- Resources grid -->
    <div class="space-y-14">
      {resources.map(section => (
        <section aria-labelledby={`section-${section.category.toLowerCase().replace(/\s+/g, '-')}`}>
          <h2 id={`section-${section.category.toLowerCase().replace(/\s+/g, '-')}`} class="flex items-center gap-2 font-serif text-xl font-bold text-[var(--color-text)] mb-6">
            <span aria-hidden="true">{section.icon}</span> {section.category}
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {section.items
              .filter(item => activeFilter === 'all' || item.niche === activeFilter)
              .map(item => (
                <div class="card-hover flex flex-col p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]">
                  <div class="flex items-start justify-between gap-3 mb-3">
                    <h3 class="font-semibold text-[var(--color-text)] text-sm">{item.title}</h3>
                    <div class="flex items-center gap-1.5 flex-shrink-0">
                      <span class="px-2 py-0.5 rounded text-xs bg-[var(--color-surface-2)] border border-[var(--color-border)] text-[var(--color-text-muted)]">{item.type}</span>
                      {item.free && (
                        <span class="px-2 py-0.5 rounded text-xs bg-green-500/10 border border-green-500/20 text-green-600">Free</span>
                      )}
                    </div>
                  </div>
                  <p class="text-sm text-[var(--color-text-muted)] flex-1 mb-4">{item.description}</p>
                  {'url' in item && item.url ? (
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="self-start text-sm font-medium text-[var(--color-brand)] hover:underline"
                    >
                      Visit tool →
                    </a>
                  ) : (
                    <button
                      class="self-start text-sm font-medium text-[var(--color-brand)] hover:underline"
                      aria-label={`Download ${item.title}`}
                    >
                      Download free →
                    </button>
                  )}
                </div>
              ))
            }
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
