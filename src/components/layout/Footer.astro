---
import { NICHES, INDUSTRIES, SITE_NAME } from '../../lib/constants';
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface-2)] mt-24" role="contentinfo">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8">

      <!-- Brand -->
      <div class="col-span-2 lg:col-span-2">
        <a href="/" class="font-serif text-xl font-bold text-gradient">{SITE_NAME}</a>
        <p class="mt-3 text-sm text-[var(--color-text-muted)] max-w-xs leading-relaxed">
          Actionable growth marketing strategies, guides, and resources for business owners and marketers.
        </p>
        <div class="mt-4 flex items-center gap-3">
          <a href="/rss.xml" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand)] transition-colors" aria-label="RSS Feed">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20 4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
          </a>
          <a href="https://twitter.com/GrowthMktHub" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand)] transition-colors" aria-label="Follow us on X (Twitter)" target="_blank" rel="noopener noreferrer">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://linkedin.com/company/growthmarketinghub" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand)] transition-colors" aria-label="Follow us on LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Content -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Content</h3>
        <ul class="space-y-2 text-sm" role="list">
          <li><a href="/blog" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">Blog</a></li>
          <li><a href="/resources" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">Resources</a></li>
          <li><a href="/niches" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">All Niches</a></li>
          <li><a href="/industries" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">All Industries</a></li>
          <li><a href="/about" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">About Us</a></li>
        </ul>
      </div>

      <!-- Niches -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Niches</h3>
        <ul class="space-y-2 text-sm" role="list">
          {NICHES.slice(0, 6).map(n => (
            <li><a href={`/niches/${n.slug}`} class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">{n.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Industries -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Industries</h3>
        <ul class="space-y-2 text-sm" role="list">
          {INDUSTRIES.slice(0, 6).map(i => (
            <li><a href={`/industries/${i.slug}`} class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">{i.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-[var(--color-border)] flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-[var(--color-text-muted)]">
      <p>&copy; {new Date().getFullYear()} {SITE_NAME}. All rights reserved.</p>
      <nav aria-label="Legal">
        <ul class="flex items-center gap-4" role="list">
          <li><a href="/privacy" class="hover:text-[var(--color-text)] transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-[var(--color-text)] transition-colors">Terms of Use</a></li>
          <li><a href="/contact" class="hover:text-[var(--color-text)] transition-colors">Contact</a></li>
        </ul>
      </nav>
    </div>
  </div>
</footer>
