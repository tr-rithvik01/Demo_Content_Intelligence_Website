---
import { buildTitle, buildCanonical, formatDateISO } from '../../utils/seo';
import { SITE_NAME, SITE_URL, SITE_DESCRIPTION, SITE_TWITTER } from '../../lib/constants';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  updatedDate?: Date;
  author?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = `${SITE_URL}/og-default.png`,
  imageAlt = SITE_NAME,
  canonical,
  type = 'website',
  publishDate,
  updatedDate,
  author,
  noindex = false,
  jsonLd,
} = Astro.props;

const resolvedTitle = buildTitle(title);
const resolvedCanonical = canonical ?? buildCanonical(Astro.url.pathname);
const resolvedImage = image.startsWith('http') ? image : `${SITE_URL}${image}`;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_NAME,
  url: SITE_URL,
  logo: `${SITE_URL}/logo.svg`,
  sameAs: [`https://twitter.com/GrowthMktHub`],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: `${SITE_URL}/search?q={search_term_string}` },
    'query-input': 'required name=search_term_string',
  },
};

const schemas = [orgSchema, websiteSchema, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Primary -->
<title>{resolvedTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={resolvedCanonical} />
{noindex && <meta name="robots" content="noindex,nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:title" content={resolvedTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:image" content={resolvedImage} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={SITE_TWITTER} />
<meta name="twitter:title" content={resolvedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedImage} />
<meta name="twitter:image:alt" content={imageAlt} />

<!-- Article specific -->
{type === 'article' && publishDate && (
  <meta property="article:published_time" content={formatDateISO(publishDate)} />
)}
{type === 'article' && updatedDate && (
  <meta property="article:modified_time" content={formatDateISO(updatedDate)} />
)}
{type === 'article' && author && (
  <meta property="article:author" content={author} />
)}

<!-- Feeds -->
<link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} Blog`} href="/rss.xml" />

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify(schemas)} />
